let no=0;
let skor=0;

function tampil(){

let s=soal[no];

document.getElementById("nomor").innerHTML=
"Soal "+(no+1)+" dari "+soal.length;

document.getElementById("gambar").innerHTML=s.gambar;

document.getElementById("soal").innerHTML=s.q;

document.getElementById("fill").style.width=
(no/soal.length*100)+"%";

let html="";

s.o.forEach((p,i)=>{
html+=`
<button class="option"
onclick="jawab(${i})">
${String.fromCharCode(65+i)}. ${p}
</button>`;
});

document.getElementById("pilihan").innerHTML=html;

}

function jawab(i){

if(i===soal[no].a){
skor++;
}

no++;

if(no<soal.length){
tampil();
}else{
selesai();
}

}

function selesai(){

document.getElementById("quiz").style.display="none";
document.getElementById("hasil").style.display="block";

let nilai=Math.round(
(skor/soal.length)*100
);

document.getElementById("nilai").innerHTML=nilai;

let pesan="";

if(nilai>=80){
pesan="🏆 Hebat! Nilaimu sangat baik!";
}
else if(nilai>=60){
pesan="👍 Bagus! Terus belajar!";
}
else{
pesan="📚 Tetap semangat belajar!";
}

document.getElementById("pesan").innerHTML=pesan;

}

tampil();

</script>

