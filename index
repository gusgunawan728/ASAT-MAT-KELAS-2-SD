<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ASAT Matematika Kelas 2 SD</title>

<style>

body{
margin:0;
font-family:'Segoe UI',sans-serif;
background:linear-gradient(135deg,#dff6ff,#fff8dc,#e8ffe8);
}

.container{
max-width:900px;
margin:auto;
padding:20px;
}

.header{
background:white;
border-radius:25px;
padding:20px;
text-align:center;
box-shadow:0 5px 15px rgba(0,0,0,.15);
margin-bottom:20px;
}

h1{
margin:0;
color:#ff9800;
font-size:40px;
}

h2{
margin:5px;
color:#2196f3;
}

.progress{
height:18px;
background:#ddd;
border-radius:20px;
overflow:hidden;
margin:15px 0;
}

.fill{
height:100%;
width:0%;
background:linear-gradient(90deg,#4caf50,#8bc34a);
transition:.5s;
}

.card{
background:white;
border-radius:25px;
padding:25px;
box-shadow:0 5px 15px rgba(0,0,0,.15);
}

.badge{
display:inline-block;
background:#2196f3;
color:white;
padding:8px 15px;
border-radius:20px;
margin-bottom:10px;
font-weight:bold;
}

.gambar{
font-size:70px;
text-align:center;
margin:10px;
}

.soal{
font-size:24px;
font-weight:bold;
margin:20px 0;
}

.option{
display:block;
width:100%;
padding:15px;
margin:10px 0;
border:none;
border-radius:15px;
background:#f3f3f3;
font-size:18px;
cursor:pointer;
text-align:left;
}

.option:hover{
background:#ffe082;
}

#hasil{
display:none;
text-align:center;
background:white;
padding:30px;
border-radius:25px;
box-shadow:0 5px 15px rgba(0,0,0,.15);
}

.nilai{
font-size:70px;
font-weight:bold;
color:#4caf50;
}

button.ulang{
background:#ff9800;
color:white;
border:none;
padding:15px 30px;
font-size:18px;
border-radius:15px;
cursor:pointer;
}

.footer{
margin-top:15px;
text-align:center;
font-size:14px;
color:#555;
}

</style>
</head>
<body>

<div class="container">

<div class="header">
<h1>🧮 ASAT MATEMATIKA</h1>
<h2>Kelas 2 SD</h2>
<p>30 Soal Pilihan Ganda</p>
</div>

<div id="quiz">

<div class="progress">
<div id="fill" class="fill"></div>
</div>

<div class="card">

<div id="nomor" class="badge"></div>

<div id="gambar" class="gambar"></div>

<div id="soal" class="soal"></div>

<div id="pilihan"></div>

</div>

</div>

<div id="hasil">

<h2>🎉 Ujian Selesai</h2>

<div id="nilai" class="nilai">100</div>

<h3 id="pesan"></h3>

<button class="ulang" onclick="location.reload()">
Ulangi Kuis
</button>

</div>

<div class="footer">
ASAT Matematika Kelas 2 SD
</div>

</div>

